---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — IAmALoop">
  <h1 class="text-3xl font-bold tracking-tight mb-6">About</h1>
  <div class="space-y-4 text-[var(--color-fg)]/90 leading-relaxed">
    <p>
      Hi, I'm Dan. I build tools and experiments — some useful, some just interesting to me.
      This site is where I collect them and write down what I'm thinking about.
    </p>
    <p>
      You can find my code on <a href="https://github.com/GitGotGood" class="text-[var(--color-accent)] hover:underline" rel="noopener">GitHub</a>.
    </p>
  </div>
</BaseLayout>
