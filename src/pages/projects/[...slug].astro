---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — IAmALoop`} description={project.data.summary}>
  <article>
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight">{project.data.title}</h1>
      <p class="text-lg text-[var(--color-muted)] mt-2">{project.data.summary}</p>
      <div class="flex flex-wrap gap-3 mt-4 text-sm">
        {
          project.data.repo && (
            <a
              href={project.data.repo}
              class="rounded border border-white/10 px-3 py-1 hover:border-[var(--color-accent)]"
              rel="noopener"
            >
              Repo ↗
            </a>
          )
        }
        {
          project.data.demo && (
            <a
              href={project.data.demo}
              class="rounded border border-white/10 px-3 py-1 hover:border-[var(--color-accent)]"
              rel="noopener"
            >
              Live demo ↗
            </a>
          )
        }
      </div>
    </header>
    <div class="prose prose-invert max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
