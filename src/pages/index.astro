---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="IAmALoop — Dan Walsh">
  <section class="mb-16">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
      Hi, I'm <span class="text-[var(--color-accent)]">Dan</span>.
    </h1>
    <p class="text-lg text-[var(--color-muted)] mt-4 max-w-2xl">
      I build creative tools and write about the loops I find myself in. This is the hub for my
      projects and thoughts.
    </p>
  </section>

  {
    projects.length > 0 && (
      <section class="mb-16">
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-2xl font-semibold tracking-tight">Featured projects</h2>
          <a href="/projects" class="text-sm text-[var(--color-muted)] hover:text-white">
            All projects →
          </a>
        </div>
        <div class="grid gap-4">
          {projects.map((p) => (
            <ProjectCard
              title={p.data.title}
              summary={p.data.summary}
              href={`/projects/${p.id}`}
              tech={p.data.tech}
            />
          ))}
        </div>
      </section>
    )
  }

  {
    articles.length > 0 && (
      <section>
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-2xl font-semibold tracking-tight">Recent writing</h2>
          <a href="/articles" class="text-sm text-[var(--color-muted)] hover:text-white">
            All articles →
          </a>
        </div>
        <ul class="space-y-4">
          {articles.map((a) => (
            <li>
              <a href={`/articles/${a.id}`} class="group block">
                <h3 class="text-lg font-medium group-hover:text-[var(--color-accent)] transition-colors">
                  {a.data.title}
                </h3>
                <p class="text-sm text-[var(--color-muted)] mt-1">{a.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
