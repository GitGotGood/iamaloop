---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Articles — IAmALoop">
  <h1 class="text-3xl font-bold tracking-tight mb-2">Articles</h1>
  <p class="text-[var(--color-muted)] mb-10">Thoughts, notes, and loops.</p>

  <ul class="space-y-6">
    {
      articles.map((a) => (
        <li>
          <a href={`/articles/${a.id}`} class="group block">
            <time class="text-xs uppercase tracking-wider text-[var(--color-muted)]">
              {fmt(a.data.date)}
            </time>
            <h2 class="text-xl font-semibold mt-1 group-hover:text-[var(--color-accent)] transition-colors">
              {a.data.title}
            </h2>
            <p class="text-[var(--color-muted)] mt-1">{a.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
